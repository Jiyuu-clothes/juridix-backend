# ─── SERVEUR ───────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ───────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ─── API PISTE (Légifrance officielle) ─────────────
# Inscription gratuite sur https://piste.gouv.fr
# Créer une application → récupérer Client ID et Client Secret
PISTE_CLIENT_ID=your_client_id_here
PISTE_CLIENT_SECRET=your_client_secret_here
PISTE_BASE_URL=https://api.piste.gouv.fr/dila/legifrance/lf-engine-app
PISTE_AUTH_URL=https://oauth.piste.gouv.fr/api/oauth/token

# ─── BASE DE DONNÉES ───────────────────────────────
DB_PATH=./db/juridix.db

# ─── RATE LIMITING ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── ADMIN BYPASS (paywall illimité pour tester) ───
# Liste d'emails séparés par des virgules. Ces comptes voient :
#   - is_premium=true côté UI
#   - allowed=true sur /api/action sans incrémenter le compteur DB
# Pratique pour tester la prod sans buter sur le paywall.
ADMIN_EMAILS=benderagh.sabry@gmail.com
